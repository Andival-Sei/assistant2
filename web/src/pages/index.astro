<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="refresh" content="0; url=/ru/" />
    <title>Assistant</title>
    <script>
      (function () {
        try {
          var lang = (navigator.language || 'ru').toLowerCase();
          var target = lang.startsWith('ru') ? '/ru/' : '/en/';
          if (location.pathname === '/' && location.hash === '' && location.search === '') {
            location.replace(target);
          }
        } catch (e) {
          // noop
        }
      })();
    </script>
  </head>
  <body>
    <p>Redirecting…</p>
    <p><a href="/ru/">Russian</a> · <a href="/en/">English</a></p>
  </body>
</html>
