---
import BaseLayout from '../../layouts/BaseLayout.astro';

const t = {
  brand: 'Assistant',
  langSwitch: 'English',
  theme: {
    system: 'Тема: Система',
    light: 'Тема: Светлая',
    dark: 'Тема: Тёмная'
  },
  hero: {
    pill: 'Личный помощник 3-в-1: Windows • Android • Web',
    title: 'Один помощник, который держит всё вместе.',
    subtitle: 'Финансы, задачи, здоровье, AI‑функции и приватность — единая экосистема, где каждое действие синхронизировано и подчиняется вашим правилам.',
    cta: 'Перейти к входу',
    ctaLink: '/ru/app/',
    metrics: [
      { tag: 'МОДУЛИ', title: 'Траты, шаги, Todo, AI, VPN', text: 'Модульная архитектура: подключаете нужное и отключаете лишнее.' },
      { tag: 'ОСНОВА', title: 'Локально‑первый подход', text: 'Критичные данные остаются на устройстве, синхронизация — по запросу.' },
      { tag: 'ПЛАТФОРМЫ', title: 'Нативные клиенты', text: 'Максимум функций и производительности на каждой платформе.' }
    ]
  },
  modules: {
    title: 'Ключевые модули на старте',
    items: [
      { title: 'Траты', text: 'Категории, лимиты, быстрый ввод, аналитика по периодам.' },
      { title: 'Шаги и здоровье', text: 'Интеграции с трекерами и сервисами, единая лента метрик.' },
      { title: 'Todo', text: 'Контекстные задачи, шаблоны, фокус‑режим.' },
      { title: 'AI‑инструменты', text: 'Сводки, поиск по заметкам, помощник решений.' },
      { title: 'VPN‑управление', text: 'Простое переключение профилей и режимов.' },
      { title: 'Интеграции', text: 'Подключение календарей, сервисов и внешних API.' }
    ]
  },
  roadmap: {
    title: 'Дорожная карта запуска',
    items: [
      { phase: 'Q1', title: 'Базовая платформа', text: 'Учёт трат, Todo, авторизация и синхронизация.' },
      { phase: 'Q2', title: 'Интеграции', text: 'Шаги, календари, базовый AI‑ассистент.' },
      { phase: 'Q3', title: 'Безопасность', text: 'VPN‑модуль и расширенная приватность.' }
    ]
  },
  security: {
    title: 'Принципы безопасности',
    items: [
      { title: 'Прозрачность', text: 'Понятные правила хранения и доступа к данным.' },
      { title: 'Гранулярные разрешения', text: 'Каждый модуль запрашивает только нужное.' },
      { title: 'Контроль синхронизации', text: 'Вы управляете тем, что уходит в облако.' }
    ]
  },
  footer: {
    note: '© 2026 Assistant. Все права защищены.',
    links: 'Политика · Условия · Контакты'
  }
};

const title = 'Assistant — личный помощник';
const description = 'Универсальный помощник для финансов, задач, здоровья и приватности.';
---
<BaseLayout lang="ru" title={title} description={description} t={t} altLangPath="/en/" />
