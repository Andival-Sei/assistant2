---
import AppLayout from '../../../layouts/AppLayout.astro';

const t = {
  brand: 'Assistant',
  langSwitch: 'English',
  theme: {
    system: 'Тема: Система',
    light: 'Тема: Светлая',
    dark: 'Тема: Тёмная'
  },
  hero: {
    pill: 'Вход в экосистему',
    title: 'Добро пожаловать обратно.',
    subtitle: 'Войдите, чтобы открыть ваши модули, задачи и приватные настройки.',
    hint: 'Пока без настоящей авторизации — это UI‑заглушка для макета.'
  },
  form: {
    title: 'Авторизация',
    email: 'Email',
    emailPlaceholder: 'you@example.com',
    password: 'Пароль',
    passwordPlaceholder: '••••••••',
    remember: 'Запомнить устройство',
    forgot: 'Забыли пароль?',
    cta: 'Войти',
    note: 'Подключим реальную авторизацию после согласования бекенда.'
  }
};

const title = 'Assistant — вход';
const description = 'Экран авторизации Assistant.';
---
<AppLayout lang="ru" title={title} description={description} t={t} altLangPath="/en/app/" />
