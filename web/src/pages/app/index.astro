<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="refresh" content="0; url=/ru/app/" />
    <title>Assistant — App</title>
    <script>
      (function () {
        try {
          var lang = (navigator.language || 'ru').toLowerCase();
          var target = lang.startsWith('ru') ? '/ru/app/' : '/en/app/';
          if (location.pathname === '/app/' || location.pathname === '/app') {
            location.replace(target);
          }
        } catch (e) {
          // noop
        }
      })();
    </script>
  </head>
  <body>
    <p>Redirecting…</p>
    <p><a href="/ru/app/">Russian</a> · <a href="/en/app/">English</a></p>
  </body>
</html>
