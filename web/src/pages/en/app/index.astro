---
import AppLayout from '../../../layouts/AppLayout.astro';

const t = {
  brand: 'Assistant',
  langSwitch: 'Русский',
  theme: {
    system: 'Theme: System',
    light: 'Theme: Light',
    dark: 'Theme: Dark'
  },
  hero: {
    pill: 'Access the ecosystem',
    title: 'Welcome back.',
    subtitle: 'Sign in to reach your modules, tasks, and private settings.',
    hint: 'UI placeholder only — real auth will come later.'
  },
  form: {
    title: 'Sign in',
    email: 'Email',
    emailPlaceholder: 'you@example.com',
    password: 'Password',
    passwordPlaceholder: '••••••••',
    remember: 'Remember this device',
    forgot: 'Forgot password?',
    cta: 'Sign in',
    note: 'We will wire real auth after backend confirmation.'
  }
};

const title = 'Assistant — sign in';
const description = 'Assistant sign-in screen.';
---
<AppLayout lang="en" title={title} description={description} t={t} altLangPath="/ru/app/" />
