---
const { lang, title, description, t, altLangPath } = Astro.props;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href="/favicon.svg" />
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700&family=Fraunces:opsz,wght@9..144,600&display=swap');

      :root {
        color-scheme: light dark;
        --bg: #f3f1ec;
        --ink: #1b1b1b;
        --muted: #4f4f4f;
        --accent: #0a6b6b;
        --accent-2: #d64b2a;
        --panel: #f8f7f4;
        --stroke: rgba(27, 27, 27, 0.14);
        --shadow: 0 18px 50px rgba(27, 27, 27, 0.12);
      }

      [data-theme='dark'] {
        --bg: #0b0f13;
        --ink: #f3f5f7;
        --muted: #c3c7d0;
        --accent: #7cd8d2;
        --accent-2: #ff8a6a;
        --panel: #121722;
        --stroke: rgba(243, 245, 247, 0.14);
        --shadow: 0 22px 60px rgba(0, 0, 0, 0.55);
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        font-family: 'Space Grotesk', system-ui, -apple-system, Segoe UI, sans-serif;
        background: radial-gradient(900px 400px at 0% 0%, rgba(10, 107, 107, 0.08), transparent),
                    radial-gradient(900px 400px at 100% 0%, rgba(214, 75, 42, 0.06), transparent),
                    var(--bg);
        color: var(--ink);
        min-height: 100vh;
      }

      body::before,
      body::after {
        content: '';
        position: fixed;
        z-index: -1;
        width: 520px;
        height: 520px;
        border-radius: 40% 60% 60% 40% / 40% 40% 60% 60%;
        filter: blur(40px);
        opacity: 0.3;
        animation: float 16s ease-in-out infinite;
      }

      body::before {
        background: #f0c2b2;
        top: -120px;
        left: -120px;
      }

      body::after {
        background: #b0dcd8;
        bottom: -160px;
        right: -140px;
        animation-delay: -6s;
      }

      a { color: inherit; text-decoration: none; }

      .wrap {
        max-width: 1100px;
        margin: 0 auto;
        padding: 28px 20px 80px;
      }

      .nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
      }

      .logo {
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .lang,
      .theme {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        border: 1px solid var(--stroke);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(6px);
        font-size: 14px;
        color: var(--ink);
      }

      .theme { cursor: pointer; }

      [data-theme='dark'] .lang,
      [data-theme='dark'] .theme,
      [data-theme='dark'] .card {
        background: rgba(18, 23, 34, 0.88);
      }

      .hero {
        display: grid;
        grid-template-columns: minmax(0, 1.2fr) minmax(0, 0.8fr);
        gap: 40px;
        margin: 52px 0 48px;
        align-items: center;
      }

      .hero h1 {
        font-family: Georgia, 'Times New Roman', serif;
        font-weight: 600;
        font-size: clamp(30px, 4.2vw, 48px);
        margin: 0 0 16px;
      }

      .hero p {
        font-size: 18px;
        color: var(--muted);
        line-height: 1.6;
        margin: 0 0 18px;
      }

      .card {
        background: rgba(255, 255, 255, 0.92);
        border: 1px solid var(--stroke);
        border-radius: 18px;
        padding: 24px;
        box-shadow: var(--shadow);
        max-width: 380px;
      }

      .form {
        display: grid;
        gap: 14px;
        margin-top: 8px;
      }

      label {
        font-size: 13px;
        color: var(--muted);
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      input {
        width: 100%;
        padding: 12px 14px;
        border-radius: 12px;
        border: 1px solid var(--stroke);
        background: rgba(255, 255, 255, 0.55);
        color: inherit;
        font-size: 15px;
      }

      [data-theme='dark'] input {
        background: rgba(12, 16, 24, 0.7);
      }

      .row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        font-size: 14px;
        color: var(--muted);
      }

      .cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 12px 16px;
        border-radius: 12px;
        background: var(--ink);
        color: #fff;
        border: none;
        cursor: pointer;
        font-weight: 600;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        box-shadow: var(--shadow);
        align-self: flex-start;
      }

      .cta:hover { transform: translateY(-2px); }

      [data-theme='dark'] .cta {
        background: linear-gradient(120deg, #f3f5f7, #cfd5df);
        color: #0b0f13;
      }

      .hint {
        font-size: 13px;
        color: var(--muted);
      }

      .pill {
        display: inline-flex;
        align-items: center;
        padding: 6px 10px;
        border-radius: 999px;
        font-size: 12px;
        background: rgba(10, 107, 107, 0.12);
        color: var(--accent);
        font-weight: 600;
      }

      .fade { opacity: 0; animation: fadeIn 0.8s ease forwards; }
      .d1 { animation-delay: 0.05s; }
      .d2 { animation-delay: 0.15s; }
      .d3 { animation-delay: 0.25s; }

      @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
      }

      @keyframes float {
        0%, 100% { transform: translateY(0) rotate(0deg); }
        50% { transform: translateY(20px) rotate(4deg); }
      }

      @media (max-width: 900px) {
        .hero { grid-template-columns: 1fr; }
      }
    </style>
    <script>
      (function () {
        var STORAGE_KEY = 'assistant-theme';
        var system = window.matchMedia('(prefers-color-scheme: dark)');
        function getTheme() {
          return localStorage.getItem(STORAGE_KEY) || 'system';
        }
        function setTheme(mode) {
          var root = document.documentElement;
          var isDark = mode === 'dark' || (mode === 'system' && system.matches);
          root.setAttribute('data-theme', isDark ? 'dark' : 'light');
          root.setAttribute('data-theme-mode', mode);
        }
        setTheme(getTheme());
        system.addEventListener('change', function () {
          if (getTheme() === 'system') setTheme('system');
        });
      })();
    </script>
  </head>
  <body>
    <div class="wrap">
      <nav class="nav">
        <div class="logo">{t.brand}</div>
        <div style="display:flex; gap:10px; align-items:center;">
          <button
            class="theme"
            id="themeToggle"
            type="button"
            data-label-system={t.theme.system}
            data-label-light={t.theme.light}
            data-label-dark={t.theme.dark}
          >
            {t.theme.system}
          </button>
          <a class="lang" href={altLangPath}>{t.langSwitch}</a>
        </div>
      </nav>

      <section class="hero">
        <div>
          <div class="pill fade d1">{t.hero.pill}</div>
          <h1 class="fade d2">{t.hero.title}</h1>
          <p class="fade d3">{t.hero.subtitle}</p>
          <p class="hint fade d3">{t.hero.hint}</p>
        </div>
        <div class="card fade d2">
          <strong>{t.form.title}</strong>
          <form class="form">
            <div>
              <label for="email">{t.form.email}</label>
              <input id="email" type="email" placeholder={t.form.emailPlaceholder} autocomplete="email" />
            </div>
            <div>
              <label for="password">{t.form.password}</label>
              <input id="password" type="password" placeholder={t.form.passwordPlaceholder} autocomplete="current-password" />
            </div>
            <div class="row">
              <span>{t.form.remember}</span>
              <span>{t.form.forgot}</span>
            </div>
            <button class="cta" type="button">{t.form.cta}</button>
            <div class="hint">{t.form.note}</div>
          </form>
        </div>
      </section>
    </div>
    <script>
      (function () {
        var STORAGE_KEY = 'assistant-theme';
        var button = document.getElementById('themeToggle');
        var order = ['system', 'light', 'dark'];
        function label(mode) {
          if (mode === 'light') return button.dataset.labelLight;
          if (mode === 'dark') return button.dataset.labelDark;
          return button.dataset.labelSystem;
        }
        function apply(mode) {
          var system = window.matchMedia('(prefers-color-scheme: dark)');
          var isDark = mode === 'dark' || (mode === 'system' && system.matches);
          document.documentElement.setAttribute('data-theme', isDark ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme-mode', mode);
          button.textContent = label(mode);
        }
        if (button) {
          var current = localStorage.getItem(STORAGE_KEY) || 'system';
          apply(current);
          button.addEventListener('click', function () {
            var mode = localStorage.getItem(STORAGE_KEY) || 'system';
            var next = order[(order.indexOf(mode) + 1) % order.length];
            localStorage.setItem(STORAGE_KEY, next);
            apply(next);
          });
        }
      })();
    </script>
  </body>
</html>
