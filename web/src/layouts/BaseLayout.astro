---
const { lang, title, description, t, altLangPath } = Astro.props;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href="/favicon.svg" />
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700&family=Fraunces:opsz,wght@9..144,600&display=swap');

      :root {
        color-scheme: light dark;
        --bg: #f6f4ef;
        --ink: #121212;
        --muted: #4b4b4b;
        --accent: #0a6b6b;
        --accent-2: #d64b2a;
        --panel: #ffffff;
        --stroke: rgba(18, 18, 18, 0.12);
        --shadow: 0 14px 40px rgba(18, 18, 18, 0.12);
      }

      [data-theme='dark'] {
        --bg: #0f1115;
        --ink: #f2f2f2;
        --muted: #b7bcc6;
        --accent: #7cd8d2;
        --accent-2: #ff8a6a;
        --panel: #171a22;
        --stroke: rgba(242, 242, 242, 0.14);
        --shadow: 0 18px 46px rgba(0, 0, 0, 0.4);
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        font-family: 'Space Grotesk', system-ui, -apple-system, Segoe UI, sans-serif;
        background: radial-gradient(1200px 500px at 10% -10%, rgba(10, 107, 107, 0.16), transparent),
                    radial-gradient(900px 500px at 90% 0%, rgba(214, 75, 42, 0.16), transparent),
                    var(--bg);
        color: var(--ink);
        min-height: 100vh;
      }

      body::before,
      body::after {
        content: '';
        position: fixed;
        z-index: -1;
        width: 520px;
        height: 520px;
        border-radius: 40% 60% 60% 40% / 40% 40% 60% 60%;
        filter: blur(40px);
        opacity: 0.3;
        animation: float 16s ease-in-out infinite;
      }

      body::before {
        background: #f2c6b7;
        top: -120px;
        left: -120px;
      }

      body::after {
        background: #b4e0dc;
        bottom: -160px;
        right: -140px;
        animation-delay: -6s;
      }

      a { color: inherit; text-decoration: none; }

      .wrap {
        max-width: 1100px;
        margin: 0 auto;
        padding: 28px 20px 80px;
      }

      .nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
      }

      .logo {
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .lang {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        border: 1px solid var(--stroke);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(6px);
        font-size: 14px;
        color: var(--ink);
      }

      [data-theme='dark'] .lang,
      [data-theme='dark'] .card,
      [data-theme='dark'] .hero-card,
      [data-theme='dark'] .roadmap-item {
        background: rgba(18, 23, 34, 0.88);
      }

      .theme {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        border: 1px solid var(--stroke);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(6px);
        font-size: 14px;
        cursor: pointer;
        color: var(--ink);
      }

      .hero {
        display: grid;
        grid-template-columns: minmax(0, 1.2fr) minmax(0, 0.8fr);
        gap: 28px;
        margin: 72px 0 48px;
      }

      .hero h1 {
        font-family: 'Fraunces', serif;
        font-weight: 600;
        font-size: clamp(36px, 5vw, 64px);
        margin: 0 0 16px;
      }

      .hero p {
        font-size: 18px;
        color: var(--muted);
        line-height: 1.6;
        margin: 0 0 24px;
      }

      .cta {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 12px 18px;
        border-radius: 10px;
        background: var(--ink);
        color: #fff;
        box-shadow: var(--shadow);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
      }

      .cta:hover { transform: translateY(-2px); box-shadow: 0 18px 46px rgba(18, 18, 18, 0.16); }

      [data-theme='dark'] .cta {
        background: linear-gradient(120deg, #f3f5f7, #cfd5df);
        color: #0b0f13;
      }

      .hero-card {
        background: var(--panel);
        border: 1px solid var(--stroke);
        border-radius: 18px;
        padding: 18px;
        box-shadow: var(--shadow);
      }

      .metric {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 12px;
        align-items: start;
        padding: 12px 0;
        border-bottom: 1px dashed var(--stroke);
      }

      .metric:last-child { border-bottom: none; }

      .pill {
        display: inline-flex;
        align-items: center;
        padding: 6px 10px;
        border-radius: 999px;
        font-size: 12px;
        background: rgba(10, 107, 107, 0.12);
        color: var(--accent);
        font-weight: 600;
      }

      .section {
        margin: 56px 0;
      }

      .section h2 {
        font-size: clamp(24px, 3.4vw, 36px);
        margin: 0 0 16px;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 16px;
      }

      .card {
        background: rgba(255, 255, 255, 0.82);
        border: 1px solid var(--stroke);
        border-radius: 14px;
        padding: 16px;
      }

      .card h3 { margin: 0 0 8px; font-size: 18px; }
      .card p { margin: 0; color: var(--muted); }

      .roadmap {
        display: grid;
        gap: 12px;
      }

      .roadmap-item {
        display: grid;
        grid-template-columns: 120px 1fr;
        gap: 16px;
        padding: 14px 16px;
        border: 1px solid var(--stroke);
        border-radius: 12px;
        background: rgba(255, 255, 255, 0.85);
      }

      .tag {
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--accent-2);
        font-weight: 700;
      }

      .footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
        border-top: 1px solid var(--stroke);
        padding-top: 16px;
        color: var(--muted);
        font-size: 14px;
      }

      .fade { opacity: 0; animation: fadeIn 0.8s ease forwards; }
      .d1 { animation-delay: 0.05s; }
      .d2 { animation-delay: 0.15s; }
      .d3 { animation-delay: 0.25s; }

      @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
      }

      @keyframes float {
        0%, 100% { transform: translateY(0) rotate(0deg); }
        50% { transform: translateY(20px) rotate(4deg); }
      }

      @media (max-width: 900px) {
        .hero { grid-template-columns: 1fr; }
        .roadmap-item { grid-template-columns: 1fr; }
      }
    </style>
    <script>
      (function () {
        var STORAGE_KEY = 'assistant-theme';
        var system = window.matchMedia('(prefers-color-scheme: dark)');
        function getTheme() {
          return localStorage.getItem(STORAGE_KEY) || 'system';
        }
        function setTheme(mode) {
          var root = document.documentElement;
          var isDark = mode === 'dark' || (mode === 'system' && system.matches);
          root.setAttribute('data-theme', isDark ? 'dark' : 'light');
          root.setAttribute('data-theme-mode', mode);
        }
        setTheme(getTheme());
        system.addEventListener('change', function () {
          if (getTheme() === 'system') setTheme('system');
        });
      })();
    </script>
  </head>
  <body>
    <div class="wrap">
      <nav class="nav">
        <div class="logo">{t.brand}</div>
        <div style="display:flex; gap:10px; align-items:center;">
          <button
            class="theme"
            id="themeToggle"
            type="button"
            data-label-system={t.theme.system}
            data-label-light={t.theme.light}
            data-label-dark={t.theme.dark}
          >
            {t.theme.system}
          </button>
          <a class="lang" href={altLangPath}>{t.langSwitch}</a>
        </div>
      </nav>

      <section class="hero">
        <div>
          <div class="pill fade d1">{t.hero.pill}</div>
          <h1 class="fade d2">{t.hero.title}</h1>
          <p class="fade d3">{t.hero.subtitle}</p>
          <a class="cta fade d3" href={t.hero.ctaLink}>{t.hero.cta}</a>
        </div>
        <div class="hero-card fade d2">
          {t.hero.metrics.map((m) => (
            <div class="metric" key={m.title}>
              <div class="tag">{m.tag}</div>
              <div>
                <strong>{m.title}</strong>
                <div style="color: var(--muted); margin-top: 4px;">{m.text}</div>
              </div>
            </div>
          ))}
        </div>
      </section>

      <section class="section">
        <h2>{t.modules.title}</h2>
        <div class="grid">
          {t.modules.items.map((item) => (
            <div class="card" key={item.title}>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="section">
        <h2>{t.roadmap.title}</h2>
        <div class="roadmap">
          {t.roadmap.items.map((item) => (
            <div class="roadmap-item" key={item.phase}>
              <div class="tag">{item.phase}</div>
              <div>
                <strong>{item.title}</strong>
                <div style="color: var(--muted); margin-top: 6px;">{item.text}</div>
              </div>
            </div>
          ))}
        </div>
      </section>

      <section class="section">
        <h2>{t.security.title}</h2>
        <div class="grid">
          {t.security.items.map((item) => (
            <div class="card" key={item.title}>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </div>
          ))}
        </div>
      </section>

      <footer class="footer">
        <div>{t.footer.note}</div>
        <div>{t.footer.links}</div>
      </footer>
    </div>
    <script>
      (function () {
        var STORAGE_KEY = 'assistant-theme';
        var button = document.getElementById('themeToggle');
        var order = ['system', 'light', 'dark'];
        function label(mode) {
          if (mode === 'light') return button.dataset.labelLight;
          if (mode === 'dark') return button.dataset.labelDark;
          return button.dataset.labelSystem;
        }
        function apply(mode) {
          var system = window.matchMedia('(prefers-color-scheme: dark)');
          var isDark = mode === 'dark' || (mode === 'system' && system.matches);
          document.documentElement.setAttribute('data-theme', isDark ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme-mode', mode);
          button.textContent = label(mode);
        }
        if (button) {
          var current = localStorage.getItem(STORAGE_KEY) || 'system';
          apply(current);
          button.addEventListener('click', function () {
            var mode = localStorage.getItem(STORAGE_KEY) || 'system';
            var next = order[(order.indexOf(mode) + 1) % order.length];
            localStorage.setItem(STORAGE_KEY, next);
            apply(next);
          });
        }
      })();
    </script>
  </body>
</html>
