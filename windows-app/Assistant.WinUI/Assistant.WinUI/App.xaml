<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Assistant.WinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Assistant.WinUI">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="PageBackgroundBrush" Color="#FFEDF2F6" />
                    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFF7FAFC" />
                    <SolidColorBrush x:Key="ShellBackgroundBrush" Color="#FFF4F7FA" />
                    <SolidColorBrush x:Key="StageBackgroundBrush" Color="#FFEDF2F6" />
                    <SolidColorBrush x:Key="InkBrush" Color="#FF18212B" />
                    <SolidColorBrush x:Key="MutedTextBrush" Color="#FF667789" />
                    <SolidColorBrush x:Key="AccentBrush" Color="#FF10B981" />
                    <SolidColorBrush x:Key="Accent2Brush" Color="#FF0F9F74" />
                    <SolidColorBrush x:Key="StrokeBrush" Color="#FFD7E0E8" />
                    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#0F18212B" />
                    <SolidColorBrush x:Key="PillBackgroundBrush" Color="#1E10B981" />
                    <SolidColorBrush x:Key="PrimaryButtonBackgroundBrush" Color="#FF18212B" />
                    <SolidColorBrush x:Key="PrimaryButtonForegroundBrush" Color="#FFFFFFFF" />
                    <SolidColorBrush x:Key="ErrorTextBrush" Color="#FFB00020" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="PageBackgroundBrush" Color="#FF0F151C" />
                    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FF1B242E" />
                    <SolidColorBrush x:Key="ShellBackgroundBrush" Color="#FF151D25" />
                    <SolidColorBrush x:Key="StageBackgroundBrush" Color="#FF0F151C" />
                    <SolidColorBrush x:Key="InkBrush" Color="#FFF3F6F8" />
                    <SolidColorBrush x:Key="MutedTextBrush" Color="#FF8F9DAC" />
                    <SolidColorBrush x:Key="AccentBrush" Color="#FF18D29A" />
                    <SolidColorBrush x:Key="Accent2Brush" Color="#FF10B981" />
                    <SolidColorBrush x:Key="StrokeBrush" Color="#FF2C3743" />
                    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#14FFFFFF" />
                    <SolidColorBrush x:Key="PillBackgroundBrush" Color="#1E18D29A" />

                    <SolidColorBrush x:Key="PrimaryButtonBackgroundBrush" Color="#FF18D29A" />
                    <SolidColorBrush x:Key="PrimaryButtonForegroundBrush" Color="#FF000000" />
                    <SolidColorBrush x:Key="ErrorTextBrush" Color="#FFFF6B6B" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
