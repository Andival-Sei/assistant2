<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Assistant.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Assistant">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" Background="{ThemeResource ShellBackgroundBrush}">
        <Grid IsHitTestVisible="False">
            <Ellipse Width="560" Height="560" Opacity="0.28" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-120,-120,0,0">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#6623E08A" Offset="0" />
                        <GradientStop Color="#0023E08A" Offset="1" />
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
            <Ellipse Width="560" Height="560" Opacity="0.28" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-140,-160">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#4017C96D" Offset="0" />
                        <GradientStop Color="#0017C96D" Offset="1" />
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
        </Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid x:Name="TopBarDragRegion" Grid.Row="0" Padding="20,12,20,10" Background="Transparent">
                    <Grid ColumnSpacing="12" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <Border Width="34" Height="34" CornerRadius="12" Background="{ThemeResource AccentBrush}">
                                <TextBlock Text="A" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource PrimaryButtonForegroundBrush}" />
                            </Border>
                            <StackPanel Spacing="0" VerticalAlignment="Center">
                                <TextBlock x:Name="LogoText" Text="ASSISTANT" FontSize="15" FontWeight="SemiBold" CharacterSpacing="140" Foreground="{ThemeResource InkBrush}" />
                                <TextBlock x:Name="WindowCaptionText" FontSize="12" Foreground="{ThemeResource MutedTextBrush}" />
                            </StackPanel>
                            <Button x:Name="LangButton" Padding="12,0" Height="32" Margin="8,0,0,0" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundBrush}" Foreground="{ThemeResource InkBrush}" CornerRadius="16">
                                <Button.Flyout>
                                    <MenuFlyout>
                                        <ToggleMenuFlyoutItem x:Name="RussianMenuItem" Click="RussianMenuItem_Click" />
                                        <ToggleMenuFlyoutItem x:Name="EnglishMenuItem" Click="EnglishMenuItem_Click" />
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>

                <Grid Grid.Row="1" Background="{ThemeResource ShellBackgroundBrush}">
                    <Grid x:Name="AuthShell" Padding="24,20,24,36">
                        <Border x:Name="AuthSurfaceCard"
                                Background="{ThemeResource LayerFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="28"
                                Padding="30"
                                Shadow="{StaticResource CardThemeShadow}"
                                Translation="0,0,24"
                                MaxWidth="432"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <StackPanel x:Name="AuthFormPanel" Spacing="20">
                                <StackPanel.RenderTransform>
                                    <TranslateTransform x:Name="AuthFormTranslate" />
                                </StackPanel.RenderTransform>

                                <StackPanel Spacing="4">
                                    <TextBlock x:Name="AuthTitleText"
                                               FontSize="32"
                                               FontWeight="SemiBold"
                                               FontFamily="Segoe UI Variable Display"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                    <TextBlock x:Name="AuthSubtitleText"
                                               FontSize="14"
                                               TextWrapping="Wrap"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>

                                <InfoBar x:Name="AuthStatusBar"
                                         IsOpen="False"
                                         IsClosable="False"
                                         Severity="Informational"
                                         Visibility="Collapsed" />

                                <Border Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="20"
                                        Padding="4">
                                    <Grid ColumnSpacing="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="LoginTab"
                                                Grid.Column="0"
                                                Click="LoginTab_Click"
                                                Style="{StaticResource AuthModeSwitchButtonStyle}" />
                                        <Button x:Name="RegisterTab"
                                                Grid.Column="1"
                                                Click="RegisterTab_Click"
                                                Style="{StaticResource AuthModeSwitchButtonStyle}" />
                                    </Grid>
                                </Border>

                                <TextBox x:Name="EmailInput"
                                         Header="EMAIL"
                                         PlaceholderText="you@example.com" />

                                <PasswordBox x:Name="PasswordInput"
                                             Header="ПАРОЛЬ"
                                             PlaceholderText="••••••••" />

                                <StackPanel x:Name="ConfirmPasswordPanel" Visibility="Collapsed">
                                    <PasswordBox x:Name="ConfirmPasswordInput"
                                                 Header="ПОВТОРИТЕ ПАРОЛЬ"
                                                 PlaceholderText="••••••••" />
                                </StackPanel>

                                <Grid x:Name="AuthAssistRow" VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox x:Name="RememberCheck"
                                              Content=""
                                              VerticalAlignment="Center" />
                                    <HyperlinkButton x:Name="ForgotButton"
                                                     Grid.Column="1"
                                                     Content=""
                                                     VerticalAlignment="Center"
                                                     Padding="4,0" />
                                </Grid>

                                <Button x:Name="SubmitButton"
                                        Style="{StaticResource AccentButtonStyle}"
                                        Padding="16,0"
                                        Height="46"
                                        HorizontalAlignment="Stretch" />

                                <Grid x:Name="AuthProviderDivider" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Height="1"
                                               Fill="{ThemeResource DividerStrokeColorDefaultBrush}"
                                               VerticalAlignment="Center" />
                                    <TextBlock x:Name="AuthDividerText"
                                               Grid.Column="1"
                                               Margin="12,0"
                                               FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <Rectangle Grid.Column="2"
                                               Height="1"
                                               Fill="{ThemeResource DividerStrokeColorDefaultBrush}"
                                               VerticalAlignment="Center" />
                                </Grid>

                                <Button x:Name="GoogleButton"
                                        Style="{StaticResource AuthSecondaryButtonStyle}"
                                        Height="46"
                                        HorizontalAlignment="Stretch"
                                        Visibility="Collapsed" />

                                <HyperlinkButton x:Name="BackToLoginButton"
                                                 Content=""
                                                 HorizontalAlignment="Left"
                                                 Padding="0"
                                                 Visibility="Collapsed" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid x:Name="DashboardShell" Visibility="Collapsed">
                        <Grid x:Name="DashboardShellLayout" ColumnSpacing="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="248" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border x:Name="SidebarSurface" Grid.Column="0" Background="{ThemeResource ShellBackgroundBrush}" Padding="16,18,16,16" VerticalAlignment="Stretch">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="1" Spacing="4">
                                            <Button x:Name="NavOverviewButton" Click="NavOverviewButton_Click" Style="{StaticResource ShellNavButtonStyle}" Foreground="{ThemeResource InkBrush}">
                                                <StackPanel Orientation="Horizontal" Spacing="12">
                                                    <Border x:Name="NavOverviewIconBox" Width="40" Height="40" CornerRadius="14" Background="{ThemeResource CardBackgroundBrush}" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="1">
                                                        <SymbolIcon Symbol="Home" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                    <TextBlock x:Name="NavOverviewLabel" VerticalAlignment="Center" FontSize="15" FontWeight="SemiBold" />
                                                </StackPanel>
                                            </Button>
                                            <Button x:Name="NavFinanceButton" Click="NavFinanceButton_Click" Style="{StaticResource ShellNavButtonStyle}" Foreground="{ThemeResource MutedTextBrush}">
                                                <StackPanel Orientation="Horizontal" Spacing="12">
                                                    <Border x:Name="NavFinanceIconBox" Width="40" Height="40" CornerRadius="14" Background="{ThemeResource CardBackgroundBrush}" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="1">
                                                        <PathIcon Data="M4 5.3h12a1.8 1.8 0 0 1 1.8 1.8v5.8A1.8 1.8 0 0 1 16 14.7H4A1.8 1.8 0 0 1 2.2 12.9V7.1A1.8 1.8 0 0 1 4 5.3Zm-1.8 3.2h15.6M6.2 11.8h2.6" HorizontalAlignment="Center" VerticalAlignment="Center" Width="18" Height="18" />
                                                    </Border>
                                                    <TextBlock x:Name="NavFinanceLabel" VerticalAlignment="Center" FontSize="15" FontWeight="SemiBold" />
                                                </StackPanel>
                                            </Button>
                                            <Button x:Name="NavHealthButton" Click="NavHealthButton_Click" Style="{StaticResource ShellNavButtonStyle}" Foreground="{ThemeResource MutedTextBrush}">
                                                <StackPanel Orientation="Horizontal" Spacing="12">
                                                    <Border x:Name="NavHealthIconBox" Width="40" Height="40" CornerRadius="14" Background="{ThemeResource CardBackgroundBrush}" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="1">
                                                        <PathIcon Data="M10 16.3 4.9 11.3A3.5 3.5 0 0 1 9.8 6.4l.2.2.2-.2a3.5 3.5 0 0 1 4.9 4.9Z" HorizontalAlignment="Center" VerticalAlignment="Center" Width="18" Height="18" />
                                                    </Border>
                                                    <TextBlock x:Name="NavHealthLabel" VerticalAlignment="Center" FontSize="15" FontWeight="SemiBold" />
                                                </StackPanel>
                                            </Button>
                                            <Button x:Name="NavTasksButton" Click="NavTasksButton_Click" Style="{StaticResource ShellNavButtonStyle}" Foreground="{ThemeResource MutedTextBrush}">
                                                <StackPanel Orientation="Horizontal" Spacing="12">
                                                    <Border x:Name="NavTasksIconBox" Width="40" Height="40" CornerRadius="14" Background="{ThemeResource CardBackgroundBrush}" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="1">
                                                        <SymbolIcon Symbol="Bullets" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                    <TextBlock x:Name="NavTasksLabel" VerticalAlignment="Center" FontSize="15" FontWeight="SemiBold" />
                                                </StackPanel>
                                            </Button>
                                            <Button x:Name="NavChatButton" Click="NavChatButton_Click" Style="{StaticResource ShellNavButtonStyle}" Foreground="{ThemeResource MutedTextBrush}">
                                                <StackPanel Orientation="Horizontal" Spacing="12">
                                                    <Border x:Name="NavChatIconBox" Width="40" Height="40" CornerRadius="14" Background="{ThemeResource CardBackgroundBrush}" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="1">
                                                        <SymbolIcon Symbol="Message" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                    <TextBlock x:Name="NavChatLabel" VerticalAlignment="Center" FontSize="15" FontWeight="SemiBold" />
                                                </StackPanel>
                                            </Button>
                                    </StackPanel>

                                    <Border Grid.Row="2" Padding="0,12,0,0" Margin="0,12,0,0">
                                        <Button x:Name="NavSettingsButton" Click="NavSettingsButton_Click" Style="{StaticResource ShellNavButtonStyle}" Foreground="{ThemeResource MutedTextBrush}">
                                            <StackPanel Orientation="Horizontal" Spacing="12">
                                                <Border x:Name="NavSettingsIconBox" Width="40" Height="40" CornerRadius="14" Background="{ThemeResource CardBackgroundBrush}" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="1">
                                                    <SymbolIcon Symbol="Setting" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <TextBlock x:Name="NavSettingsLabel" VerticalAlignment="Center" FontSize="15" FontWeight="SemiBold" />
                                            </StackPanel>
                                        </Button>
                                    </Border>
                                </Grid>
                            </Border>

                            <Border x:Name="DashboardStageSurface" Grid.Column="1" Background="{ThemeResource PageBackgroundBrush}" BorderThickness="0" CornerRadius="28,0,0,0" Padding="0" Margin="0" VerticalAlignment="Stretch">
                                <Grid Padding="20,16,20,24">
                                    <StackPanel x:Name="DashboardContentStack" Spacing="18" HorizontalAlignment="Stretch">
                                    <ScrollViewer x:Name="CompactPrimaryNavScroller" Visibility="Collapsed" HorizontalScrollMode="Auto" HorizontalScrollBarVisibility="Hidden" VerticalScrollMode="Disabled" VerticalScrollBarVisibility="Disabled">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Button x:Name="CompactNavOverviewButton" Click="NavOverviewButton_Click" Style="{StaticResource ShellCompactNavButtonStyle}">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <SymbolIcon Symbol="Home" />
                                                    <TextBlock x:Name="CompactNavOverviewLabel" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                            <Button x:Name="CompactNavFinanceButton" Click="NavFinanceButton_Click" Style="{StaticResource ShellCompactNavButtonStyle}">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <PathIcon Data="M4 5.3h12a1.8 1.8 0 0 1 1.8 1.8v5.8A1.8 1.8 0 0 1 16 14.7H4A1.8 1.8 0 0 1 2.2 12.9V7.1A1.8 1.8 0 0 1 4 5.3Zm-1.8 3.2h15.6M6.2 11.8h2.6" Width="18" Height="18" />
                                                    <TextBlock x:Name="CompactNavFinanceLabel" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                            <Button x:Name="CompactNavHealthButton" Click="NavHealthButton_Click" Style="{StaticResource ShellCompactNavButtonStyle}">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <PathIcon Data="M10 16.3 4.9 11.3A3.5 3.5 0 0 1 9.8 6.4l.2.2.2-.2a3.5 3.5 0 0 1 4.9 4.9Z" Width="18" Height="18" />
                                                    <TextBlock x:Name="CompactNavHealthLabel" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                            <Button x:Name="CompactNavTasksButton" Click="NavTasksButton_Click" Style="{StaticResource ShellCompactNavButtonStyle}">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <SymbolIcon Symbol="Bullets" />
                                                    <TextBlock x:Name="CompactNavTasksLabel" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                            <Button x:Name="CompactNavChatButton" Click="NavChatButton_Click" Style="{StaticResource ShellCompactNavButtonStyle}">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <SymbolIcon Symbol="Message" />
                                                    <TextBlock x:Name="CompactNavChatLabel" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                            <Button x:Name="CompactNavSettingsButton" Click="NavSettingsButton_Click" Style="{StaticResource ShellCompactNavButtonStyle}">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <SymbolIcon Symbol="Setting" />
                                                    <TextBlock x:Name="CompactNavSettingsLabel" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </ScrollViewer>
                                <Grid x:Name="DashboardSummaryRow" ColumnSpacing="18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="280" />
                                    </Grid.ColumnDefinitions>

                                    <Border x:Name="DashboardHeroCard" Background="{ThemeResource CardBackgroundBrush}" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="0.6" CornerRadius="28" Padding="22" Shadow="{StaticResource CardThemeShadow}" Translation="0,0,56">
                                        <StackPanel Spacing="8">
                                            <TextBlock x:Name="DashboardLabel" FontSize="11" Foreground="{ThemeResource AccentBrush}" CharacterSpacing="120" />
                                            <TextBlock x:Name="DashboardWelcomeTitle" FontSize="42" LineHeight="46" FontWeight="ExtraBold" TextWrapping="Wrap" Foreground="{ThemeResource InkBrush}" />
                                            <TextBlock x:Name="DashboardSubtitle" FontSize="14" TextWrapping="Wrap" Foreground="{ThemeResource MutedTextBrush}" />
                                        </StackPanel>
                                    </Border>

                                    <Border x:Name="DashboardStatusCard" Grid.Column="1" Background="{ThemeResource CardBackgroundBrush}" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="0.6" CornerRadius="24" Padding="18" Shadow="{StaticResource CardThemeShadow}" Translation="0,0,46">
                                        <StackPanel Spacing="8">
                                            <Border Background="{ThemeResource PillBackgroundBrush}" CornerRadius="999" Padding="10,6" HorizontalAlignment="Left">
                                                <TextBlock x:Name="DashboardStatusBadge" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}" />
                                            </Border>
                                            <TextBlock x:Name="DashboardStatusTitle" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource InkBrush}" />
                                            <TextBlock x:Name="DashboardStatusBody" FontSize="12" TextWrapping="Wrap" Foreground="{ThemeResource MutedTextBrush}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Border x:Name="SecondaryTabsCard" Background="{ThemeResource CardBackgroundBrush}" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="0.6" CornerRadius="22" Padding="10" Shadow="{StaticResource CardThemeShadow}" Translation="0,0,36">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button x:Name="SecondaryTabOneButton" Click="SecondaryTabOneButton_Click" Padding="14,8" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="1" CornerRadius="14" />
                                        <Button x:Name="SecondaryTabTwoButton" Click="SecondaryTabTwoButton_Click" Padding="14,8" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="1" CornerRadius="14" />
                                        <Button x:Name="SecondaryTabThreeButton" Click="SecondaryTabThreeButton_Click" Padding="14,8" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="1" CornerRadius="14" />
                                        <Button x:Name="SecondaryTabFourButton" Click="SecondaryTabFourButton_Click" Padding="14,8" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="1" CornerRadius="14" />
                                    </StackPanel>
                                </Border>

                                <Border x:Name="PlaceholderCard" Background="{ThemeResource CardBackgroundBrush}" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="0.6" CornerRadius="28" Padding="28" Opacity="1" Shadow="{StaticResource CardThemeShadow}" Translation="0,0,60">
                                    <Border.RenderTransform>
                                        <TranslateTransform x:Name="PlaceholderTranslate" />
                                    </Border.RenderTransform>
                                    <StackPanel Spacing="14" VerticalAlignment="Center">
                                        <Border Background="{ThemeResource PillBackgroundBrush}" CornerRadius="999" Padding="10,6" HorizontalAlignment="Left">
                                            <TextBlock x:Name="PlaceholderBadge" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}" />
                                        </Border>
                                        <TextBlock x:Name="PlaceholderTitle" FontSize="34" FontWeight="ExtraBold" Foreground="{ThemeResource InkBrush}" />
                                        <TextBlock x:Name="PlaceholderBody" FontSize="15" TextWrapping="Wrap" Foreground="{ThemeResource MutedTextBrush}" />
                                    </StackPanel>
                                </Border>

                                <StackPanel x:Name="SettingsContent" Visibility="Collapsed" Spacing="18" HorizontalAlignment="Stretch">
                                    <StackPanel.RenderTransform>
                                        <TranslateTransform x:Name="SettingsTranslate" />
                                    </StackPanel.RenderTransform>

                                    <InfoBar x:Name="SettingsStatusBar"
                                             IsOpen="False"
                                             IsClosable="False"
                                             Visibility="Collapsed" />

                                    <TextBlock x:Name="SettingsLoadingText" FontSize="13" Foreground="{ThemeResource MutedTextBrush}" Visibility="Collapsed" />

                                    <Border x:Name="SettingsProfileCard" Background="{ThemeResource CardBackgroundBrush}" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="0.6" CornerRadius="28" Padding="22" Shadow="{StaticResource CardThemeShadow}">
                                        <StackPanel Spacing="16">
                                            <StackPanel Spacing="4">
                                                <TextBlock x:Name="SettingsProfileTitle" FontSize="22" FontWeight="SemiBold" Foreground="{ThemeResource InkBrush}" />
                                                <TextBlock x:Name="SettingsProfileBody" FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource MutedTextBrush}" />
                                            </StackPanel>

                                            <StackPanel Spacing="8">
                                                <TextBlock x:Name="SettingsDisplayNameLabel" FontSize="12" Foreground="{ThemeResource MutedTextBrush}" />
                                                <Grid ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox x:Name="SettingsDisplayNameInput" Background="{ThemeResource InputBackgroundBrush}" BorderBrush="{ThemeResource StrokeBrush}" CornerRadius="10" />
                                                    <Button x:Name="SettingsDisplayNameButton" Grid.Column="1" Click="SettingsDisplayNameButton_Click" Padding="14,0" Height="40" CornerRadius="14" />
                                                </Grid>
                                            </StackPanel>

                                            <StackPanel Spacing="8">
                                                <TextBlock x:Name="SettingsEmailTitle" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource InkBrush}" />
                                                <TextBlock x:Name="SettingsEmailBody" FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource MutedTextBrush}" />
                                                <TextBlock x:Name="SettingsEmailLabel" FontSize="12" Foreground="{ThemeResource MutedTextBrush}" />
                                                <Grid ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox x:Name="SettingsEmailInput" Background="{ThemeResource InputBackgroundBrush}" BorderBrush="{ThemeResource StrokeBrush}" CornerRadius="10" />
                                                    <Button x:Name="SettingsEmailButton" Grid.Column="1" Click="SettingsEmailButton_Click" Padding="14,0" Height="40" CornerRadius="14" />
                                                </Grid>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <Border x:Name="SettingsPreferencesCard" Background="{ThemeResource CardBackgroundBrush}" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="0.6" CornerRadius="28" Padding="22" Shadow="{StaticResource CardThemeShadow}">
                                        <StackPanel Spacing="16">
                                            <StackPanel Spacing="4">
                                                <TextBlock x:Name="SettingsPreferencesTitle" FontSize="22" FontWeight="SemiBold" Foreground="{ThemeResource InkBrush}" />
                                                <TextBlock x:Name="SettingsPreferencesBody" FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource MutedTextBrush}" />
                                            </StackPanel>

                                            <StackPanel Spacing="8">
                                                <TextBlock x:Name="SettingsGeminiTitle" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource InkBrush}" />
                                                <TextBlock x:Name="SettingsGeminiBody" FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource MutedTextBrush}" />
                                                <ToggleSwitch x:Name="SettingsAiEnhancementsToggle" Toggled="SettingsAiEnhancementsToggle_Toggled" />
                                                <Grid ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <PasswordBox x:Name="SettingsGeminiInput" Background="{ThemeResource InputBackgroundBrush}" BorderBrush="{ThemeResource StrokeBrush}" CornerRadius="10" PasswordChanged="SettingsGeminiInput_PasswordChanged" />
                                                    <Button x:Name="SettingsGeminiButton" Grid.Column="1" Click="SettingsGeminiButton_Click" Padding="14,0" Height="40" CornerRadius="14" />
                                                </Grid>
                                                <Grid ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock x:Name="SettingsGeminiStateText" FontSize="12" Foreground="{ThemeResource MutedTextBrush}" VerticalAlignment="Center" TextWrapping="Wrap" />
                                                    <HyperlinkButton x:Name="SettingsGeminiClearButton" Grid.Column="1" Click="SettingsGeminiClearButton_Click" Padding="0" VerticalAlignment="Center" />
                                                </Grid>
                                                <HyperlinkButton x:Name="SettingsGeminiLinkButton" Click="SettingsGeminiLinkButton_Click" Padding="0" HorizontalAlignment="Left" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <Border x:Name="SettingsSecurityCard" Background="{ThemeResource CardBackgroundBrush}" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="0.6" CornerRadius="28" Padding="22" Shadow="{StaticResource CardThemeShadow}">
                                        <StackPanel Spacing="18">
                                            <StackPanel Spacing="4">
                                                <TextBlock x:Name="SettingsSecurityTitle" FontSize="22" FontWeight="SemiBold" Foreground="{ThemeResource InkBrush}" />
                                                <TextBlock x:Name="SettingsSecurityBody" FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource MutedTextBrush}" />
                                            </StackPanel>

                                            <StackPanel Spacing="8">
                                                <TextBlock x:Name="SettingsPasswordTitle" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource InkBrush}" />
                                                <TextBlock x:Name="SettingsPasswordBody" FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource MutedTextBrush}" />
                                                <Grid ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Spacing="6">
                                                        <TextBlock x:Name="SettingsPasswordLabel" FontSize="12" Foreground="{ThemeResource MutedTextBrush}" />
                                                        <PasswordBox x:Name="SettingsPasswordInput" Background="{ThemeResource InputBackgroundBrush}" BorderBrush="{ThemeResource StrokeBrush}" CornerRadius="10" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Spacing="6">
                                                        <TextBlock x:Name="SettingsPasswordConfirmLabel" FontSize="12" Foreground="{ThemeResource MutedTextBrush}" />
                                                        <PasswordBox x:Name="SettingsPasswordConfirmInput" Background="{ThemeResource InputBackgroundBrush}" BorderBrush="{ThemeResource StrokeBrush}" CornerRadius="10" />
                                                    </StackPanel>
                                                </Grid>
                                                <Button x:Name="SettingsPasswordButton" Click="SettingsPasswordButton_Click" Padding="14,0" Height="40" HorizontalAlignment="Left" CornerRadius="14" />
                                            </StackPanel>

                                            <Border Background="{ThemeResource PageBackgroundBrush}" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="1" CornerRadius="20" Padding="16">
                                                <Grid ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Spacing="4">
                                                        <TextBlock x:Name="SettingsGoogleTitle" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource InkBrush}" />
                                                        <TextBlock x:Name="SettingsGoogleBody" FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource MutedTextBrush}" />
                                                    </StackPanel>
                                                    <Button x:Name="SettingsGoogleButton" Grid.Column="1" Click="SettingsGoogleButton_Click" Padding="14,0" Height="40" CornerRadius="14" VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>

                                            <Border Background="{ThemeResource PageBackgroundBrush}" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="1" CornerRadius="20" Padding="16">
                                                <Grid ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Spacing="4">
                                                        <TextBlock x:Name="SettingsLogoutTitle" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource InkBrush}" />
                                                        <TextBlock x:Name="SettingsLogoutBody" FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource MutedTextBrush}" />
                                                    </StackPanel>
                                                    <Button x:Name="SettingsLogoutButton" Grid.Column="1" Click="LogoutButton_Click" Padding="14,0" Height="40" CornerRadius="14" VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>

                                            <Border Background="{ThemeResource PageBackgroundBrush}" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="1" CornerRadius="20" Padding="16">
                                                <Grid ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Spacing="4">
                                                        <TextBlock x:Name="SettingsDeleteTitle" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource InkBrush}" />
                                                        <TextBlock x:Name="SettingsDeleteBody" FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource MutedTextBrush}" />
                                                    </StackPanel>
                                                    <Button x:Name="SettingsDeleteButton" Grid.Column="1" Click="SettingsDeleteButton_Click" Padding="14,0" Height="40" CornerRadius="14" VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <StackPanel x:Name="FinanceContent" Visibility="Collapsed" Spacing="18" HorizontalAlignment="Stretch">
                                    <StackPanel.RenderTransform>
                                        <TranslateTransform x:Name="FinanceTranslate" />
                                    </StackPanel.RenderTransform>
                                    <Border Background="Transparent" BorderThickness="0" Padding="0">
                                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                            <Button x:Name="FinanceAddTransactionButton" Click="FinanceAddTransactionButton_Click" Padding="14,8" Background="{ThemeResource PrimaryButtonBackgroundBrush}" Foreground="{ThemeResource PrimaryButtonForegroundBrush}" BorderThickness="0" CornerRadius="16" />
                                            <Button x:Name="FinanceAddAccountButton" Click="FinanceAddAccountButton_Click" Padding="14,8" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="1" CornerRadius="16" />
                                            <Button x:Name="FinanceConfigureOverviewButton" Click="FinanceConfigureOverviewButton_Click" Padding="14,8" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="1" CornerRadius="16" />
                                        </StackPanel>
                                    </Border>

                                    <Border Background="{ThemeResource CardBackgroundBrush}" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="0.6" CornerRadius="22" Padding="10" Shadow="{StaticResource CardThemeShadow}" Translation="0,0,40">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Button x:Name="FinanceOverviewTabButton" Click="FinanceOverviewTabButton_Click" Padding="14,8" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="1" CornerRadius="16" />
                                            <Button x:Name="FinanceAccountsTabButton" Click="FinanceAccountsTabButton_Click" Padding="14,8" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="1" CornerRadius="16" />
                                            <Button x:Name="FinanceTransactionsTabButton" Click="FinanceTransactionsTabButton_Click" Padding="14,8" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="1" CornerRadius="16" />
                                            <Button x:Name="FinanceCategoriesTabButton" Click="FinanceCategoriesTabButton_Click" Padding="14,8" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="1" CornerRadius="16" />
                                            <Button x:Name="FinanceAnalyticsTabButton" Click="FinanceAnalyticsTabButton_Click" Padding="14,8" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="1" CornerRadius="16" />
                                        </StackPanel>
                                    </Border>

                                    <StackPanel x:Name="FinanceOverviewBoard" Visibility="Collapsed" Spacing="18">
                                        <StackPanel x:Name="FinanceOverviewCardsPanel" Spacing="12" />
                                    </StackPanel>

                                    <Border x:Name="FinanceLoadingCard" Visibility="Collapsed" Background="{ThemeResource CardBackgroundBrush}" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="0.6" CornerRadius="28" Padding="22" Shadow="{StaticResource CardThemeShadow}" Translation="0,0,36">
                                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                            <ProgressRing x:Name="FinanceProgressRing" Width="24" Height="24" IsActive="True" />
                                            <TextBlock x:Name="FinanceLoadingText" FontSize="14" Foreground="{ThemeResource MutedTextBrush}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Border>

                                    <Border x:Name="FinanceErrorCard" Visibility="Collapsed" Background="{ThemeResource CardBackgroundBrush}" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="0.6" CornerRadius="28" Padding="22" Shadow="{StaticResource CardThemeShadow}" Translation="0,0,36">
                                        <StackPanel Spacing="10">
                                            <TextBlock x:Name="FinanceErrorTitle" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource InkBrush}" />
                                            <TextBlock x:Name="FinanceErrorText" FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource ErrorTextBrush}" />
                                            <Button x:Name="FinanceRetryButton" Click="FinanceRetryButton_Click" Padding="14,8" HorizontalAlignment="Left" Background="{ThemeResource PrimaryButtonBackgroundBrush}" Foreground="{ThemeResource PrimaryButtonForegroundBrush}" BorderThickness="0" CornerRadius="16" />
                                        </StackPanel>
                                    </Border>

                                    <Border x:Name="FinanceOnboardingCard" Visibility="Collapsed" Background="{ThemeResource CardBackgroundBrush}" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="0.6" CornerRadius="28" Padding="22" Shadow="{StaticResource CardThemeShadow}" Translation="0,0,44">
                                        <StackPanel Spacing="14">
                                            <Border Background="{ThemeResource PillBackgroundBrush}" CornerRadius="999" Padding="10,6" HorizontalAlignment="Left">
                                                <TextBlock x:Name="FinanceOnboardingBadge" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}" />
                                            </Border>
                                            <TextBlock x:Name="FinanceOnboardingTitle" FontSize="24" FontWeight="SemiBold" Foreground="{ThemeResource InkBrush}" />
                                            <TextBlock x:Name="FinanceOnboardingSubtitle" FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource MutedTextBrush}" />

                                            <StackPanel x:Name="FinanceOnboardingStepOnePanel" Spacing="10">
                                                <TextBlock x:Name="FinanceCurrencyLabel" FontSize="13" Foreground="{ThemeResource MutedTextBrush}" />
                                                <ComboBox x:Name="FinanceCurrencyCombo" />
                                            </StackPanel>

                                            <StackPanel x:Name="FinanceOnboardingStepTwoPanel" Visibility="Collapsed" Spacing="10">
                                                <TextBlock x:Name="FinanceBankLabel" FontSize="13" Foreground="{ThemeResource MutedTextBrush}" />
                                                <ComboBox x:Name="FinanceBankCombo" />
                                                <TextBox x:Name="FinancePrimaryBalanceInput" />
                                            </StackPanel>

                                            <StackPanel x:Name="FinanceOnboardingStepThreePanel" Visibility="Collapsed" Spacing="10">
                                                <TextBlock x:Name="FinanceCashLabel" FontSize="13" Foreground="{ThemeResource MutedTextBrush}" />
                                                <TextBox x:Name="FinanceCashInput" />
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <Button x:Name="FinanceBackButton" Click="FinanceBackButton_Click" Padding="14,8" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="1" CornerRadius="16" />
                                                <Button x:Name="FinanceNextButton" Click="FinanceNextButton_Click" Padding="14,8" Background="{ThemeResource PrimaryButtonBackgroundBrush}" Foreground="{ThemeResource PrimaryButtonForegroundBrush}" BorderThickness="0" CornerRadius="16" />
                                                <Button x:Name="FinanceSkipButton" Click="FinanceSkipButton_Click" Padding="14,8" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="1" CornerRadius="16" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <Grid x:Name="FinanceDataGrid" Visibility="Collapsed" ColumnSpacing="18" HorizontalAlignment="Stretch">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition x:Name="FinancePrimaryColumn" Width="1.15*" />
                                            <ColumnDefinition x:Name="FinanceSecondaryColumn" Width="0.85*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Spacing="18">
                                            <Border x:Name="FinanceBalanceCard" Visibility="Collapsed" Background="{ThemeResource CardBackgroundBrush}" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="1" CornerRadius="28" Padding="22">
                                                <StackPanel Spacing="14">
                                                    <StackPanel x:Name="FinanceBalanceSummaryStack" Spacing="8">
                                                        <TextBlock x:Name="FinanceBalanceLabel" FontSize="11" Foreground="{ThemeResource AccentBrush}" CharacterSpacing="120" />
                                                        <TextBlock x:Name="FinanceBalanceText" FontSize="32" FontWeight="ExtraBold" Foreground="{ThemeResource InkBrush}" />
                                                        <TextBlock x:Name="FinanceBalanceHint" FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource MutedTextBrush}" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>

                                            <StackPanel x:Name="FinanceAccountsCard" Visibility="Collapsed" Spacing="12">
                                                <TextBlock x:Name="FinanceAccountsTitle" FontSize="20" FontWeight="SemiBold" Foreground="{ThemeResource InkBrush}" />
                                                <StackPanel x:Name="FinanceAccountsPanel" Spacing="12" />
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Spacing="18">
                                            <Border x:Name="FinanceTransactionsCard" Background="{ThemeResource CardBackgroundBrush}" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="0.6" CornerRadius="28" Padding="22" Shadow="{StaticResource CardThemeShadow}" Translation="0,0,40">
                                                <StackPanel Spacing="14">
                                                    <TextBlock x:Name="FinanceTransactionsTitle" FontSize="20" FontWeight="SemiBold" Foreground="{ThemeResource InkBrush}" />
                                                    <StackPanel x:Name="FinanceTransactionsPanel" Spacing="10" />
                                                </StackPanel>
                                            </Border>

                                            <Border x:Name="FinanceSettingsCard" Background="{ThemeResource CardBackgroundBrush}" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="1" CornerRadius="28" Padding="22">
                                                <StackPanel Spacing="10">
                                                    <TextBlock x:Name="FinanceSettingsTitle" FontSize="20" FontWeight="SemiBold" Foreground="{ThemeResource InkBrush}" />
                                                    <TextBlock x:Name="FinanceSettingsText" FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource MutedTextBrush}" />
                                                    <StackPanel x:Name="FinanceSettingsPanel" Spacing="10" />
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>

                                <Grid x:Name="LegacyMetricsGrid" Visibility="Collapsed" ColumnSpacing="14" RowSpacing="14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Background="{ThemeResource CardBackgroundBrush}" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="1" CornerRadius="22" Padding="18">
                                        <StackPanel Spacing="8">
                                            <TextBlock x:Name="MetricOneLabel" FontSize="12" Foreground="{ThemeResource MutedTextBrush}" />
                                            <TextBlock x:Name="MetricOneValue" FontSize="28" FontWeight="Bold" Foreground="{ThemeResource InkBrush}" />
                                            <TextBlock x:Name="MetricOneDetail" FontSize="12" Foreground="{ThemeResource MutedTextBrush}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Background="{ThemeResource CardBackgroundBrush}" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="1" CornerRadius="22" Padding="18">
                                        <StackPanel Spacing="8">
                                            <TextBlock x:Name="MetricTwoLabel" FontSize="12" Foreground="{ThemeResource MutedTextBrush}" />
                                            <TextBlock x:Name="MetricTwoValue" FontSize="28" FontWeight="Bold" Foreground="{ThemeResource InkBrush}" />
                                            <TextBlock x:Name="MetricTwoDetail" FontSize="12" Foreground="{ThemeResource MutedTextBrush}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Background="{ThemeResource CardBackgroundBrush}" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="1" CornerRadius="22" Padding="18">
                                        <StackPanel Spacing="8">
                                            <TextBlock x:Name="MetricThreeLabel" FontSize="12" Foreground="{ThemeResource MutedTextBrush}" />
                                            <TextBlock x:Name="MetricThreeValue" FontSize="28" FontWeight="Bold" Foreground="{ThemeResource InkBrush}" />
                                            <TextBlock x:Name="MetricThreeDetail" FontSize="12" Foreground="{ThemeResource MutedTextBrush}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="3" Background="{ThemeResource CardBackgroundBrush}" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="1" CornerRadius="22" Padding="18">
                                        <StackPanel Spacing="8">
                                            <TextBlock x:Name="MetricFourLabel" FontSize="12" Foreground="{ThemeResource MutedTextBrush}" />
                                            <TextBlock x:Name="MetricFourValue" FontSize="28" FontWeight="Bold" Foreground="{ThemeResource InkBrush}" />
                                            <TextBlock x:Name="MetricFourDetail" FontSize="12" Foreground="{ThemeResource MutedTextBrush}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Grid x:Name="LegacyDetailsGrid" Visibility="Collapsed" ColumnSpacing="18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.25*" />
                                        <ColumnDefinition Width="0.75*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Background="{ThemeResource CardBackgroundBrush}" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="1" CornerRadius="28" Padding="22">
                                        <StackPanel Spacing="16">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock x:Name="ActivityLabel" FontSize="11" Foreground="{ThemeResource AccentBrush}" CharacterSpacing="120" />
                                                    <TextBlock x:Name="ActivityTitle" FontSize="22" FontWeight="SemiBold" Foreground="{ThemeResource InkBrush}" />
                                                </StackPanel>
                                                <TextBlock x:Name="ActivityHint" Grid.Column="1" FontSize="12" Foreground="{ThemeResource MutedTextBrush}" />
                                            </Grid>

                                            <StackPanel Spacing="16">
                                                <Grid ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="14" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Ellipse Width="12" Height="12" Fill="{ThemeResource AccentBrush}" Margin="0,6,0,0" />
                                                    <StackPanel Grid.Column="1" Spacing="4">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock x:Name="ActivityOneTitle" FontSize="15" FontWeight="SemiBold" Foreground="{ThemeResource InkBrush}" />
                                                            <TextBlock x:Name="ActivityOneTime" Grid.Column="1" FontSize="12" Foreground="{ThemeResource MutedTextBrush}" />
                                                        </Grid>
                                                        <TextBlock x:Name="ActivityOneBody" FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource MutedTextBrush}" />
                                                    </StackPanel>
                                                </Grid>

                                                <Grid ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="14" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Ellipse Width="12" Height="12" Fill="{ThemeResource AccentBrush}" Margin="0,6,0,0" />
                                                    <StackPanel Grid.Column="1" Spacing="4">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock x:Name="ActivityTwoTitle" FontSize="15" FontWeight="SemiBold" Foreground="{ThemeResource InkBrush}" />
                                                            <TextBlock x:Name="ActivityTwoTime" Grid.Column="1" FontSize="12" Foreground="{ThemeResource MutedTextBrush}" />
                                                        </Grid>
                                                        <TextBlock x:Name="ActivityTwoBody" FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource MutedTextBrush}" />
                                                    </StackPanel>
                                                </Grid>

                                                <Grid ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="14" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Ellipse Width="12" Height="12" Fill="{ThemeResource AccentBrush}" Margin="0,6,0,0" />
                                                    <StackPanel Grid.Column="1" Spacing="4">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock x:Name="ActivityThreeTitle" FontSize="15" FontWeight="SemiBold" Foreground="{ThemeResource InkBrush}" />
                                                            <TextBlock x:Name="ActivityThreeTime" Grid.Column="1" FontSize="12" Foreground="{ThemeResource MutedTextBrush}" />
                                                        </Grid>
                                                        <TextBlock x:Name="ActivityThreeBody" FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource MutedTextBrush}" />
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <StackPanel Grid.Column="1" Spacing="18">
                                        <Border Background="{ThemeResource CardBackgroundBrush}" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="1" CornerRadius="28" Padding="22">
                                            <StackPanel Spacing="12">
                                                <TextBlock x:Name="FocusLabel" FontSize="11" Foreground="{ThemeResource AccentBrush}" CharacterSpacing="120" />
                                                <TextBlock x:Name="FocusTitle" FontSize="22" FontWeight="SemiBold" Foreground="{ThemeResource InkBrush}" />
                                                <StackPanel Spacing="10">
                                                    <TextBlock x:Name="FocusOne" FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource InkBrush}" />
                                                    <TextBlock x:Name="FocusTwo" FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource InkBrush}" />
                                                    <TextBlock x:Name="FocusThree" FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource InkBrush}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <Border Background="{ThemeResource CardBackgroundBrush}" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="1" CornerRadius="28" Padding="22">
                                            <StackPanel Spacing="12">
                                                <TextBlock x:Name="InsightLabel" FontSize="11" Foreground="{ThemeResource AccentBrush}" CharacterSpacing="120" />
                                                <TextBlock x:Name="InsightTitle" FontSize="22" FontWeight="SemiBold" Foreground="{ThemeResource InkBrush}" />
                                                <Border Background="{ThemeResource PageBackgroundBrush}" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="1" CornerRadius="20" Padding="16">
                                                    <StackPanel Spacing="8">
                                                        <TextBlock x:Name="InsightLead" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" Foreground="{ThemeResource InkBrush}" />
                                                        <TextBlock x:Name="InsightBody" FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource MutedTextBrush}" />
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </Border>

                                        <Border Background="{ThemeResource CardBackgroundBrush}" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="1" CornerRadius="28" Padding="22">
                                            <StackPanel Spacing="12">
                                                <TextBlock x:Name="StateLabel" FontSize="11" Foreground="{ThemeResource AccentBrush}" CharacterSpacing="120" />
                                                <TextBlock x:Name="StateTitle" FontSize="22" FontWeight="SemiBold" Foreground="{ThemeResource InkBrush}" />
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Web" FontSize="13" Foreground="{ThemeResource MutedTextBrush}" />
                                                    <TextBlock x:Name="StateWeb" Grid.Column="1" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource InkBrush}" />
                                                    <TextBlock Grid.Row="1" Text="Windows" FontSize="13" Foreground="{ThemeResource MutedTextBrush}" Margin="0,10,0,0" />
                                                    <TextBlock x:Name="StateWindows" Grid.Row="1" Grid.Column="1" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource InkBrush}" Margin="0,10,0,0" />
                                                    <TextBlock Grid.Row="2" Text="Android" FontSize="13" Foreground="{ThemeResource MutedTextBrush}" Margin="0,10,0,0" />
                                                    <TextBlock x:Name="StateAndroid" Grid.Row="2" Grid.Column="1" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource InkBrush}" Margin="0,10,0,0" />
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
